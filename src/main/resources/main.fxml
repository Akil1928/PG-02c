<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="736.0" prefWidth="902.0" styleClass="root-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainController">

    <top>
        <VBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="902.0" spacing="6.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="18.0" left="32.0" right="32.0" top="18.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <Label styleClass="header-badge" text="PG-02" />
                        <Label styleClass="header-title" text="Recursividad Avanzada y Tipos de Algoritmos en JavaFx">
                            <font><Font size="26.0" /></font>
                        </Label>
                    </children>
                </HBox>
                <Label styleClass="header-sub" text="IF-3001 · Algoritmos y Estructuras de Datos">
                    <font><Font size="13.0" /></font>
                </Label>
            </children>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" prefHeight="200.0" prefWidth="200.0" styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>

                <Tab text="Binaria">
                    <content>
                        <SplitPane dividerPositions="0.5" prefHeight="200.0" prefWidth="200.0">
                            <items>
                                <VBox prefHeight="200.0" prefWidth="100.0" spacing="8.0" styleClass="panel">
                                    <children>
                                        <Label styleClass="panel-title" text="Búsqueda Binaria O(log n) . Solución con la Técnicas Divide y Vencerás" />
                                        <ScrollPane prefWidth="1300.0">
                                            <content>
                                                <Label fx:id="lblBinArray" styleClass="array-label" text="BinArray" />
                                            </content>
                                        </ScrollPane>
                                        <Canvas fx:id="canvasBin" height="320.0" styleClass="tree-canvas" width="600.0" />
                                        <ProgressBar fx:id="progressBarBin" maxWidth="Infinity" progress="0" />
                                        <HBox spacing="16" styleClass="legend-row">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="4">
                                                    <children>
                                                        <Label style="-fx-text-fill:#E74C3C; -fx-font-size:14;" text="■" />
                                                        <Label styleClass="legend-item" text="Comparando" />
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" spacing="4">
                                                    <children>
                                                        <Label style="-fx-text-fill:#8896A5; -fx-font-size:14;" text="■" />
                                                        <Label styleClass="legend-item" text="Visitado" />
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" spacing="4">
                                                    <children>
                                                        <Label style="-fx-text-fill:#1A8C7B; -fx-font-size:14;" text="■" />
                                                        <Label styleClass="legend-item" text="Encontrado" />
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT" spacing="4">
                                                    <children>
                                                        <Label style="-fx-text-fill:#1F3868; -fx-font-size:14;" text="■" />
                                                        <Label styleClass="legend-item" text="Sin visitar" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" styleClass="panel">
                                    <children>
                                        <Label styleClass="action-label" text="Parámetros" />
                                        <HBox>
                                            <children>
                                                <Label styleClass="param-label" text="Tamaño del arreglo = " />
                                                <Label fx:id="lblBinSize" styleClass="value-badge" text="5" />
                                            </children>
                                        </HBox>
                                        <Slider fx:id="sliderBinSize" showTickLabels="true" />
                                        <HBox layoutX="10.0" layoutY="37.0">
                                            <children>
                                                <Label styleClass="param-label" text="Elemento a buscar:" />
                                                <TextField fx:id="txtBinValue" styleClass="target-field" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="8.0">
                                            <children>
                                                <Button fx:id="btnBinGen" mnemonicParsing="false" styleClass="btn-secondary" text="Generar Arreglo" />
                                                <Button fx:id="btnBinSearch" mnemonicParsing="false" styleClass="btn-primary" text="Buscar" />
                                            </children>
                                        </HBox>
                                        <HBox layoutX="10.0" layoutY="142.0" spacing="8.0">
                                            <children>
                                                <Button fx:id="btnBinAnimate" mnemonicParsing="false" styleClass="btn-accent" text="Animar" />
                                                <Button fx:id="btnBinReset" mnemonicParsing="false" styleClass="btn-ghost" text="Limpiar" />
                                            </children>
                                        </HBox>
                                        <Label styleClass="stat-label" text="Resultado" />
                                        <VBox spacing="6.0" styleClass="result-box">
                                            <children>
                                                <Label fx:id="lblBinResult" styleClass="result-text" text="--" />
                                            </children>
                                        </VBox>
                                        <GridPane hgap="8.0" vgap="8.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints vgrow="SOMETIMES" />
                                                <RowConstraints vgrow="SOMETIMES" />
                                            </rowConstraints>
                                            <children>
                                                <VBox styleClass="stat-card">
                                                    <children>
                                                        <Label styleClass="stat-label" text="Comparaciones" />
                                                        <Label fx:id="lblBinComps" styleClass="stat-value" text="--" />
                                                    </children>
                                                </VBox>
                                                <VBox styleClass="stat-card" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label styleClass="stat-label" text="Tiempo" />
                                                        <Label fx:id="lblBinTime" styleClass="stat-value-sm" text="--" />
                                                    </children>
                                                </VBox>
                                                <VBox styleClass="stat-card green-card" GridPane.rowIndex="1">
                                                    <children>
                                                        <Label styleClass="stat-label" text="Complejidad" />
                                                        <Label fx:id="lblBinComplexity" styleClass="stat-value" text="--" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>
                                        <Label styleClass="section-label" text="Pasos de ejecución" />
                                        <ListView fx:id="listBinSteps" prefHeight="160.0" styleClass="steps-list" />
                                        <VBox styleClass="info-box">
                                            <children>
                                                <Label styleClass="info-title" text="Búsqueda Binaria" />
                                                <Label styleClass="info-item" text="• Requiere arreglo ordenado · O(log n)" />
                                                <Label styleClass="info-item" text="• Divide el espacio a la mitad en cada paso" />
                                                <Label styleClass="info-item" text="• mid = lo + hi / 2" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>

                <Tab text="N-Reinas">
                    <content>
                        <SplitPane dividerPositions="0.65" prefHeight="200.0" prefWidth="200.0">
                            <items>
                                <VBox spacing="10.0" styleClass="panel">
                                    <children>
                                        <Label styleClass="panel-title" text="Tablero N-Reinas. Solución con la Técnica Backtracking (Búsquedas Exhaustivas)" />
                                        <StackPane fx:id="stackPaneBoard" style="-fx-background-color: #f4f6fa; -fx-padding: 20;" VBox.vgrow="ALWAYS">
                                            <GridPane fx:id="gridBoard" alignment="CENTER" style="-fx-background-color: white; -fx-border-color: #1A8C7B; -fx-border-width: 2;" />
                                        </StackPane>
                                    </children>
                                </VBox>

                                <VBox prefWidth="300.0" spacing="15.0" styleClass="panel">
                                    <padding>
                                        <Insets bottom="15" left="15" right="15" top="15" />
                                    </padding>
                                    <children>
                                        <Label styleClass="action-label" text="Configuración" />
                                        <HBox spacing="10">
                                            <children>
                                                <ToggleButton fx:id="toggle4x4" maxWidth="Infinity" selected="true" style="-fx-alignment: #66ccff;" text="4 x 4" HBox.hgrow="ALWAYS" />
                                                <ToggleButton fx:id="toggle8x8" maxWidth="Infinity" style="-fx-alignment: #66ccff;" text="8 x 8" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <Label styleClass="param-label" text="Velocidad:" />
                                        <Slider fx:id="sliderQueenSpeed" max="10" min="1" value="5" />

                                        <HBox spacing="8.0">
                                            <children>
                                                <Button fx:id="btnQueenResolve" maxWidth="Infinity" styleClass="btn-primary" text="Resolver" HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnQueenAnimate" maxWidth="Infinity" styleClass="btn-accent" text="Animar" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="8.0">
                                            <children>
                                                <Button fx:id="btnQueenStop" maxWidth="Infinity" styleClass="btn-secondary" text="Detener" HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnQueenClear" maxWidth="Infinity" styleClass="btn-ghost" text="Limpiar" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <Label styleClass="stat-label" text="Estadísticas de Backtracking" />
                                        <VBox styleClass="stat-card">
                                            <children>
                                                <Label styleClass="stat-label-sm" text="Llamadas Recursivas" />
                                                <Label fx:id="lblQueenCalls" styleClass="stat-value" text="0" />
                                            </children>
                                        </VBox>

                                        <Label styleClass="section-label" text="Registro de Pasos" />
                                        <ListView fx:id="listQueenSteps" styleClass="steps-list" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>

                <Tab text="Monedas">
                    <content>
                        <SplitPane dividerPositions="0.66" prefHeight="636.0" prefWidth="902.0">
                            <items>
                                <ScrollPane fitToHeight="true" fitToWidth="true">
                                    <content>
                                        <VBox prefWidth="580.0" spacing="12.0" style="-fx-background-color: white; -fx-padding: 14;">
                                            <children>
                                                <Label styleClass="panel-title" text="Cambio de monedas . Solución con la Técnica Algoritmos Voraces (Greedy)" />
                                                <Canvas fx:id="CanvasCoin" height="304.0" width="558.0" />

                                                <TableView fx:id="tableViewCoin" prefHeight="220.0" prefWidth="560.0" style="-fx-background-color: white; -fx-border-color: #E8ECF2; -fx-border-radius: 4; -fx-font-size: 12px;">
                                                    <columns>
                                                        <TableColumn fx:id="colMoneda" prefWidth="130.0" text="Moneda" />
                                                        <TableColumn fx:id="colCantidad" prefWidth="130.0" text="Cantidad" />
                                                        <TableColumn fx:id="colMonto" prefWidth="130.0" text="Monto" />
                                                        <TableColumn fx:id="colRestante" prefWidth="130.0" text="Restante" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>

                                <VBox prefWidth="307.0" spacing="10.0" style="-fx-background-color: #F4F6FA;">
                                    <padding>
                                        <Insets bottom="16.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;" text="Parámetros">
                                            <padding>
                                                <Insets left="4.0" />
                                            </padding>
                                        </Label>

                                        <Slider fx:id="sliderCoinAmount" blockIncrement="0.0" majorTickUnit="1000" max="0.0" showTickLabels="true" showTickMarks="true">
                                            <padding>
                                                <Insets left="4.0" right="4.0" />
                                            </padding>
                                        </Slider>

                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <padding>
                                                <Insets left="4.0" />
                                            </padding>
                                            <children>
                                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0D1B4B;" text="Monto en ₡:" />
                                                <TextField fx:id="txtCoinValue" prefHeight="26.0" prefWidth="145.0" style="-fx-font-size: 13px;" />
                                            </children>
                                        </HBox>

                                        <HBox spacing="8.0">
                                            <padding>
                                                <Insets left="4.0" />
                                            </padding>
                                            <children>
                                                <Button fx:id="btnCoinChange" mnemonicParsing="false" styleClass="btn-primary" text="Cambio de monedas" />
                                                <Button fx:id="btnLimpiarMonedas" mnemonicParsing="false" styleClass="btn-ghost" text="Limpiar" />
                                            </children>
                                        </HBox>

                                        <Label styleClass="section-label" text="Pasos de ejecución">
                                            <padding>
                                                <Insets left="4.0" top="4.0" />
                                            </padding>
                                        </Label>

                                        <ListView fx:id="listCoinSteps" prefHeight="235.0" prefWidth="290.0" styleClass="steps-list">
                                            <placeholder>
                                                <Label style="-fx-text-fill: #8896A5; -fx-font-size: 11px;" />
                                            </placeholder>
                                        </ListView>

                                        <VBox spacing="4.0" style="-fx-background-color: #1F3868; -fx-background-radius: 4; -fx-padding: 10;">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: white;" text="Denominaciones de monedas en colones" />
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #ADBDD4;" text="500, 100, 50, 25, 10, 5, 1" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
